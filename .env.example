# PostgreSQL connection string.
# Local dev: point at a local Postgres or a Railway dev database.
# On Railway: set this as a reference variable -> ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentinella

# Secret used to sign session tokens. Generate one with:
#   openssl rand -base64 48
AUTH_SECRET=change-me-to-a-long-random-string

# Optional, comma-separated list of invite codes. When set, registration
# requires one of these codes (compared trimmed and case-insensitively),
# which is how access stays limited to your specific traveler group.
# Leave unset or empty to open registration to anyone — the register form
# then hides the invite field entirely.
INVITE_CODES=ITALIA-2026

# Comma-separated list of emails that get the admin role on registration.
# Admins can publish safety alerts from the Alerts screen.
ADMIN_EMAILS=you@example.com

# Shared secret for the scheduled-job endpoints (/api/cron/*). Generate a
# long random value (openssl rand -hex 32) and use the same value in the
# Railway cron services' Authorization header. Unset = cron endpoints refuse
# all calls.
CRON_SECRET=

# Web Push (notifications). Generate the key pair with:
#   npx web-push generate-vapid-keys
# VAPID_SUBJECT is a contact for push services, as a mailto: URL.
# Leave all three unset to disable push — sends become logged no-ops.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
